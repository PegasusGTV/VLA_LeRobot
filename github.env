# GitHub identity — source before tools that need it, e.g.:
#   set -a && . ./github.env && set +a
# After git init, apply to this repo:
#   git config user.name "$GIT_USER_NAME"
#   git config user.email "$GIT_USER_EMAIL"

GITHUB_USERNAME=PegasusGTV
GIT_USER_NAME=PegasusGTV
# No-reply address (works if enabled under https://github.com/settings/emails ).
# Replace with your real verified email if you want it on commits instead.
GIT_USER_EMAIL=tvgopalakrishnan5@gmail.com
